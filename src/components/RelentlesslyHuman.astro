---
/**
 * RelentlesslyHuman — Interactive collaborative poem
 * Strangers contribute one line at a time to an ever-growing poem.
 */
---

<section class="rh" id="relentlessly-human" aria-label="Relentlessly Human — A collaborative poem">

  <!-- A. The Invitation -->
  <div class="rh__invitation reveal" data-reveal="fade-up">
    <h2 class="rh__title">Relentlessly Human</h2>
    <p class="rh__subtitle">
      A poem being written by strangers, for strangers.<br />
      One line at a time. No AI. Only what you carry inside.
    </p>
  </div>

  <!-- A.2 Live Stats -->
  <div class="rh__stats reveal" data-reveal="fade-up" data-reveal-delay="50" aria-live="polite">
    <div class="rh__stat">
      <span class="rh__stat-number" id="rh-line-count">—</span>
      <span class="rh__stat-label">lines written</span>
    </div>
    <span class="rh__stat-divider" aria-hidden="true"></span>
    <div class="rh__stat">
      <span class="rh__stat-number" id="rh-author-count">—</span>
      <span class="rh__stat-label">voices heard</span>
    </div>
  </div>

  <!-- B. Reading Controls -->
  <div class="rh__controls reveal" data-reveal="fade-up" data-reveal-delay="100">
    <div class="rh__pills" role="group" aria-label="Number of lines to display">
      <button class="rh__pill" data-limit="5" aria-pressed="false">Last 5</button>
      <button class="rh__pill is-active" data-limit="10" aria-pressed="true">Last 10</button>
      <button class="rh__pill" data-limit="50" aria-pressed="false">Last 50</button>
      <button class="rh__pill" data-limit="0" aria-pressed="false">None</button>
      <a href="/poem" class="rh__pill rh__pill--link">All</a>
    </div>
    <div class="rh__depth" aria-live="polite">
      <span class="rh__depth-text"></span>
    </div>
  </div>

  <!-- C. The Poem Display -->
  <div class="rh__poem-container reveal" data-reveal="fade-up" data-reveal-delay="200">
    <div class="rh__loading" aria-live="polite">
      <span class="rh__loading-dot"></span>
      <span class="rh__loading-dot"></span>
      <span class="rh__loading-dot"></span>
    </div>
    <div class="rh__poem" role="list" aria-label="Poem lines">
      <!-- Lines injected by JS -->
    </div>
    <div class="rh__empty" hidden>
      <p>No lines yet. Be the first to write.</p>
    </div>
    <noscript>
      <p class="rh__noscript">This collaborative poem requires JavaScript to load and display lines from contributors around the world.</p>
    </noscript>
  </div>

  <!-- D. The Contribution Area -->
  <div class="rh__contribute" id="rh-contribute" hidden>
    <div class="rh__contribute-card reveal" data-reveal="fade-up">

      <div class="rh__context">
        <p class="rh__context-label">The poem so far...</p>
        <div class="rh__context-lines" aria-hidden="true">
          <!-- Last few lines shown as context -->
        </div>
      </div>

      <!-- Replying-to indicator (shown when replying to a specific line) -->
      <div class="rh__replying-to" id="rh-replying-to" hidden>
        <span class="rh__replying-to-label">Replying to:</span>
        <span class="rh__replying-to-text"></span>
        <button type="button" class="rh__replying-to-cancel" id="rh-replying-to-cancel" aria-label="Cancel reply">&times;</button>
      </div>

      <form class="rh__form" id="rh-form" novalidate>
        <div class="rh__season-banner" id="rh-season-banner" hidden></div>
        <p class="rh__prompt" id="rh-prompt" aria-live="polite"></p>
        <div class="rh__form-group rh__form-group--line">
          <label for="rh-line-input" class="rh__label">Add your line</label>
          <div class="rh__input-wrap">
            <input
              type="text"
              id="rh-line-input"
              class="rh__input rh__input--line"
              maxlength="150"
              placeholder="Write something only a human could feel"
              autocomplete="off"
              required
            />
            <span class="rh__char-count" aria-live="polite">0 / 150</span>
          </div>
        </div>

        <div class="rh__form-group">
          <label for="rh-name-input" class="rh__label">Your name</label>
          <input
            type="text"
            id="rh-name-input"
            class="rh__input"
            maxlength="100"
            placeholder="First name or pen name"
            autocomplete="given-name"
            required
          />
        </div>

        <div class="rh__form-group">
          <span class="rh__label rh__label--optional">Connect with you <span class="rh__optional">(optional — pick any)</span></span>
          <div class="rh__socials">
            <div class="rh__social-field">
              <label for="rh-linkedin" class="rh__social-label" aria-label="LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </label>
              <input type="text" id="rh-linkedin" class="rh__input rh__input--social" maxlength="200" placeholder="Profile URL or handle" data-social="linkedin" />
            </div>
            <div class="rh__social-field">
              <label for="rh-instagram" class="rh__social-label" aria-label="Instagram">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </label>
              <input type="text" id="rh-instagram" class="rh__input rh__input--social" maxlength="200" placeholder="@handle or profile URL" data-social="instagram" />
            </div>
            <div class="rh__social-field">
              <label for="rh-email" class="rh__social-label" aria-label="Email">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </label>
              <input type="email" id="rh-email" class="rh__input rh__input--social" maxlength="200" placeholder="your@email.com" data-social="email" />
            </div>
            <div class="rh__social-field">
              <label for="rh-website" class="rh__social-label" aria-label="Website">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </label>
              <input type="url" id="rh-website" class="rh__input rh__input--social" maxlength="200" placeholder="yoursite.com" data-social="website" />
            </div>
          </div>
        </div>

        <div class="rh__form-group rh__form-group--lang">
          <label for="rh-lang" class="rh__label rh__label--optional">
            Language <span class="rh__optional">(if not English)</span>
          </label>
          <input
            type="text"
            id="rh-lang"
            class="rh__input rh__input--lang"
            maxlength="30"
            placeholder="e.g. Español, Français, 日本語"
            autocomplete="language"
          />
        </div>

        <div class="rh__form-group rh__form-group--location">
          <span class="rh__label rh__label--optional">
            Where are you from? <span class="rh__optional">(optional)</span>
          </span>
          <div class="rh__location-fields">
            <input
              type="text"
              id="rh-city"
              class="rh__input rh__input--location"
              maxlength="100"
              placeholder="City"
              autocomplete="address-level2"
            />
            <input
              type="text"
              id="rh-country"
              class="rh__input rh__input--location"
              maxlength="100"
              placeholder="Country"
              autocomplete="country-name"
            />
          </div>
        </div>

        <div class="rh__form-group rh__form-group--chain">
          <label class="rh__chain-opt-in">
            <input type="checkbox" id="rh-chain-notify" />
            <span class="rh__chain-label">
              Notify me when someone writes the next line after mine
            </span>
          </label>
          <input
            type="email"
            id="rh-chain-email"
            class="rh__input rh__input--chain-email"
            placeholder="your@email.com"
            hidden
          />
        </div>

        <div class="rh__audio" id="rh-audio">
          <span class="rh__label rh__label--optional">Read your line aloud <span class="rh__optional">(optional)</span></span>
          <div class="rh__audio-controls">
            <button type="button" class="rh__audio-btn" id="rh-audio-record">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z"/><path d="M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"/></svg>
              <span id="rh-audio-btn-text">Record</span>
            </button>
            <div class="rh__audio-wave" id="rh-audio-wave" hidden>
              <canvas id="rh-audio-canvas" width="200" height="40"></canvas>
            </div>
            <div class="rh__audio-preview" id="rh-audio-preview" hidden>
              <button type="button" class="rh__audio-play" id="rh-audio-play" aria-label="Play recording">&#9654;</button>
              <span class="rh__audio-duration" id="rh-audio-duration"></span>
              <button type="button" class="rh__audio-delete" id="rh-audio-delete" aria-label="Delete recording">&#10005;</button>
            </div>
            <span class="rh__audio-timer" id="rh-audio-timer" hidden>0:00 / 0:10</span>
          </div>
        </div>

        <div class="rh__covenant">
          <label class="rh__covenant-label">
            <input type="checkbox" id="rh-covenant" class="rh__covenant-check" required />
            <span class="rh__covenant-box" aria-hidden="true"></span>
            <span class="rh__covenant-text">I wrote this myself. No AI. Just me.</span>
          </label>
        </div>

        <button type="submit" class="rh__submit" id="rh-submit" disabled>
          <span class="rh__submit-text">Add to the poem</span>
          <span class="rh__submit-sending" hidden>Sending...</span>
        </button>

        <div class="rh__error" id="rh-error" role="alert" hidden></div>
      </form>
    </div>
  </div>

  <!-- D (alt). Already contributed state -->
  <div class="rh__contributed" id="rh-contributed" hidden>
    <div class="rh__contributed-card reveal" data-reveal="fade-up">
      <p class="rh__contributed-text">You've left your mark. Thank you.</p>
      <div class="rh__notify" id="rh-notify">
        <p class="rh__notify-text">Get notified when someone writes after you:</p>
        <form class="rh__notify-form" id="rh-notify-form">
          <label for="rh-notify-email" class="sr-only">Email for notifications</label>
          <input type="email" id="rh-notify-email" class="rh__input rh__input--notify" placeholder="your@email.com" required />
          <button type="submit" class="rh__notify-btn" id="rh-notify-btn">Notify me</button>
        </form>
        <p class="rh__notify-done" id="rh-notify-done" hidden>We'll let you know.</p>
      </div>

      <div class="rh__invite">
        <p class="rh__invite-text">Invite someone to write the next line:</p>
        <div class="rh__invite-actions">
          <button class="rh__invite-btn" id="rh-invite-copy" type="button">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <span id="rh-invite-copy-label">Copy link</span>
          </button>
          <button class="rh__invite-btn" id="rh-invite-share" type="button">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
            Share
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- E. The Afterglow -->
  <div class="rh__afterglow" id="rh-afterglow" hidden>
    <p class="rh__afterglow-text reveal" data-reveal="fade-up">
      Someone, someday, will read what you just wrote.
    </p>
  </div>

  <!-- F. Keep scrolling hint — links to poems section -->
  <a href="#poems" class="rh__scroll-hint reveal" data-reveal="fade" data-reveal-delay="400">
    <span class="rh__scroll-hint-text">Keep exploring</span>
    <svg class="rh__scroll-hint-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 5v14" /><path d="m19 12-7 7-7-7" />
    </svg>
  </a>

</section>

<script src="../scripts/relentlessly-human.js"></script>
