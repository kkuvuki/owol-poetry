---
// Supabase table required:
// CREATE TABLE letters (
//   id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
//   addressed_to TEXT NOT NULL,
//   body TEXT NOT NULL CHECK (char_length(body) <= 500),
//   signed_from TEXT DEFAULT 'a stranger',
//   hearts INTEGER DEFAULT 0,
//   created_at TIMESTAMPTZ DEFAULT now(),
//   flagged BOOLEAN DEFAULT false
// );

import Base from '../layouts/Base.astro';
---

<Base
  title="Letters to Strangers — OwOL"
  description="Leave anonymous letters for people you'll never meet. A digital post office for the human heart."
>
  <article class="letters">
    <header class="letters__header reveal" data-reveal="fade-up">
      <h1 class="letters__title">Letters to Strangers</h1>
      <p class="page-intro">Write a letter to someone you've never met. It could be to a stranger, to your future self, or to anyone who needs to hear it. Letters are anonymous and public — anyone who visits can read them and offer a heart.</p>
      <p class="letters__subtitle">Leave words for someone you'll never meet.</p>
    </header>

    <!-- Write Section -->
    <section class="letters__write reveal" data-reveal="fade-up">
      <form class="letters__form" id="letters-form" autocomplete="off">
        <div class="letters__field">
          <label class="letters__label" for="letters-to">To:</label>
          <input
            type="text"
            id="letters-to"
            class="letters__input"
            placeholder="the one who almost stayed"
            maxlength="120"
            required
          />
          <div class="letters__suggestions-label">or try one of these:</div>
          <div class="letters__suggestions">
            <button type="button" class="letters__suggestion" data-to="my younger self">my younger self</button>
            <button type="button" class="letters__suggestion" data-to="the stranger on the train">the stranger on the train</button>
            <button type="button" class="letters__suggestion" data-to="anyone who needs this today">anyone who needs this today</button>
            <button type="button" class="letters__suggestion" data-to="the one I never thanked">the one I never thanked</button>
          </div>
        </div>

        <div class="letters__field">
          <label class="letters__label sr-only" for="letters-body">Your letter</label>
          <textarea
            id="letters-body"
            class="letters__textarea"
            placeholder="Write your letter..."
            maxlength="500"
            rows="6"
            required
          ></textarea>
          <span class="letters__char-count" id="letters-char-count">0 / 500</span>
        </div>

        <div class="letters__field letters__field--sign">
          <label class="letters__label" for="letters-from">From:</label>
          <input
            type="text"
            id="letters-from"
            class="letters__input letters__input--from"
            placeholder="a fellow traveler"
            maxlength="80"
          />
        </div>

        <button type="submit" class="letters__submit" id="letters-submit">
          Leave this letter
        </button>

        <p class="letters__status" id="letters-status" aria-live="polite" hidden></p>
      </form>
    </section>

    <!-- Browse Section -->
    <section class="letters__browse reveal" data-reveal="fade-up">
      <div class="letters__browse-header">
        <h2 class="letters__browse-title">Open a letter</h2>
        <button class="letters__shuffle-btn" id="letters-shuffle" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
          Find another letter
        </button>
      </div>

      <div class="letters__loading" id="letters-loading" aria-live="polite">
        <span class="sr-only">Loading letters</span>
        <span class="rh__loading-dot"></span>
        <span class="rh__loading-dot"></span>
        <span class="rh__loading-dot"></span>
      </div>

      <div class="letters__grid" id="letters-grid" role="list" aria-label="Anonymous letters">
        <!-- Letters injected by JS -->
      </div>
    </section>

    <footer class="letters__footer reveal" data-reveal="fade-up">
      <a href="/" class="letters__back">&larr; Back to Ravings</a>
    </footer>
  </article>
</Base>

<style>
  .letters {
    max-width: 52rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }

  /* Header */
  .letters__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .letters__title {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-text-primary, #EFF0ED);
    margin: 0 0 0.5rem;
  }

  .letters__subtitle {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--color-text-muted, #A6A5A0);
    margin: 0;
  }

  /* Write Section */
  .letters__write {
    margin-bottom: 4rem;
    background: linear-gradient(135deg, #2a2520 0%, #252017 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    padding: 2.5rem 2rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .letters__write:focus-within {
    border-color: rgba(121, 185, 57, 0.2);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(121, 185, 57, 0.1);
  }

  .letters__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .letters__field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    position: relative;
  }

  .letters__field--sign {
    flex-direction: row;
    align-items: center;
    gap: 0.6rem;
  }

  .letters__label {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--color-text-muted, #A6A5A0);
  }

  .letters__input,
  .letters__textarea {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: 1rem;
    color: var(--color-text-primary, #EFF0ED);
    background: var(--color-bg-elevated, #252119);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    padding: 0.65rem 0.85rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    width: 100%;
  }

  .letters__input:focus,
  .letters__textarea:focus {
    border-color: var(--color-accent-green, #79B939);
    box-shadow: 0 0 0 3px rgba(121, 185, 57, 0.15);
  }

  .letters__input::placeholder,
  .letters__textarea::placeholder {
    color: var(--color-text-muted, #A6A5A0);
    font-style: italic;
  }

  .letters__input--from {
    flex: 1;
  }

  .letters__textarea {
    resize: vertical;
    min-height: 7rem;
    line-height: 1.7;
  }

  .letters__char-count {
    font-size: 0.78rem;
    color: var(--color-text-muted, #A6A5A0);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .letters__char-count--warn {
    color: var(--color-accent-caution, #D4A843);
  }

  .letters__char-count--full {
    color: var(--color-accent-error, #E55C5C);
  }

  .letters__suggestions-label {
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 0.7rem;
    color: var(--color-text-muted, #A6A5A0);
    letter-spacing: 0.06em;
    margin-top: 0.5rem;
    opacity: 0.7;
  }

  .letters__suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.2rem;
  }

  .letters__suggestion {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: 0.78rem;
    font-style: italic;
    color: var(--color-text-muted, #A6A5A0);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 0.25rem 0.7rem;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .letters__suggestion:hover {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-text-secondary, #B0B1AB);
  }

  .letters__submit {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: 1rem;
    font-style: italic;
    color: var(--color-text-secondary, #B0B1AB);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    padding: 0.75rem 1.5rem;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    align-self: flex-end;
  }

  .letters__submit:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .letters__submit:active {
    transform: scale(0.98);
  }

  .letters__submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .letters__submit--sending {
    position: relative;
    color: transparent;
    pointer-events: none;
  }

  .letters__submit--sending::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 16px;
    height: 16px;
    margin: -8px 0 0 -8px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: var(--color-text-secondary, #B0B1AB);
    border-radius: 50%;
    animation: letters-spin 0.6s linear infinite;
  }

  @keyframes letters-spin {
    to { transform: rotate(360deg); }
  }

  .letters__status {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: 0.9rem;
    font-style: italic;
    text-align: center;
    color: var(--color-accent-success, #8BC48B);
    margin: 0;
  }

  .letters__status--error {
    color: var(--color-accent-error, #E55C5C);
  }

  /* Browse Section */
  .letters__browse {
    margin-bottom: 3rem;
  }

  .letters__browse-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .letters__browse-title {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--color-text-primary, #EFF0ED);
    margin: 0;
  }

  .letters__shuffle-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-text-muted, #A6A5A0);
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    padding: 0.45rem 0.9rem;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }

  .letters__shuffle-btn:hover {
    color: var(--color-text-secondary, #B0B1AB);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .letters__shuffle-btn:active {
    transform: scale(0.95);
  }

  .letters__loading {
    display: flex;
    justify-content: center;
    gap: 0.3rem;
    padding: 2rem 0;
  }

  .letters__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* Letter Card */
  .letters__card {
    background: linear-gradient(145deg, #2a2520 0%, #252017 50%, #201c15 100%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 2px;
    padding: 1.8rem 1.6rem 1.4rem;
    box-shadow:
      0 1px 4px rgba(0, 0, 0, 0.15),
      0 4px 16px rgba(0, 0, 0, 0.1);
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
  }

  .letters__card:nth-child(3n+1) {
    transform: rotate(-0.6deg);
  }

  .letters__card:nth-child(3n+2) {
    transform: rotate(0.4deg);
  }

  .letters__card:nth-child(3n+3) {
    transform: rotate(-0.2deg);
  }

  .letters__card:hover {
    transform: rotate(0deg) translateY(-2px);
    box-shadow:
      0 2px 8px rgba(0, 0, 0, 0.2),
      0 8px 24px rgba(0, 0, 0, 0.15);
  }

  /* Faux paper edge */
  .letters__card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.06) 10%,
      rgba(255, 255, 255, 0.1) 30%,
      rgba(255, 255, 255, 0.06) 50%,
      rgba(255, 255, 255, 0.1) 70%,
      rgba(255, 255, 255, 0.06) 90%,
      transparent 100%
    );
    border-radius: 2px 2px 0 0;
    opacity: 0.7;
  }

  .letters__card-to {
    font-style: italic;
    font-size: 0.88rem;
    color: var(--color-text-muted, #A6A5A0);
    margin: 0 0 0.75rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .letters__card-body {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--color-text-secondary, #B0B1AB);
    margin: 0 0 1rem;
    white-space: pre-line;
    word-break: break-word;
  }

  .letters__card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .letters__card-from {
    font-style: italic;
    font-size: 0.82rem;
    color: var(--color-text-muted, #A6A5A0);
  }

  .letters__heart-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: 0.8rem;
    color: var(--color-text-muted, #A6A5A0);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.3rem 0.5rem;
    border-radius: 3px;
    transition: color 0.2s, background 0.15s;
  }

  .letters__heart-btn:hover {
    color: var(--color-accent-heart, #C47A6A);
    background: rgba(196, 122, 106, 0.1);
  }

  .letters__heart-btn--active {
    color: var(--color-accent-heart, #C47A6A);
  }

  .letters__heart-icon {
    font-size: 1rem;
    line-height: 1;
    transition: transform 0.2s;
  }

  .letters__heart-btn:active .letters__heart-icon {
    transform: scale(1.3);
  }

  :global(.letters__heart-icon--pop) {
    animation: heart-pop 0.4s ease both;
  }

  @keyframes heart-pop {
    0%   { transform: scale(1); }
    30%  { transform: scale(1.5); }
    50%  { transform: scale(0.9); }
    70%  { transform: scale(1.2); }
    100% { transform: scale(1); }
  }

  .letters__empty {
    grid-column: 1 / -1;
    text-align: center;
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-style: italic;
    color: var(--color-text-muted, #A6A5A0);
    padding: 3rem 0;
  }

  /* Card entrance animation */
  @keyframes letter-appear {
    from {
      opacity: 0;
      transform: translateY(12px) rotate(0deg);
    }
    to {
      opacity: 1;
    }
  }

  .letters__card--animate {
    animation: letter-appear 0.4s ease both;
  }

  /* Footer */
  .letters__footer {
    text-align: center;
    padding-top: 2rem;
  }

  .letters__back {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: 0.9rem;
    color: var(--color-text-muted, #A6A5A0);
    text-decoration: none;
    transition: color 0.2s;
  }

  .letters__back:hover {
    color: var(--color-text-primary, #EFF0ED);
  }

  /* Responsive */
  @media (max-width: 600px) {
    .letters {
      padding: 2.5rem 1rem 4rem;
    }

    .letters__write {
      padding: 1.5rem 1.2rem;
    }

    .letters__grid {
      grid-template-columns: 1fr;
    }

    .letters__card:nth-child(n) {
      transform: rotate(0deg);
    }

    .letters__card:hover {
      transform: translateY(-2px);
    }
  }
</style>

<script>
  import { supabase } from '../scripts/supabase.js';

  var allLetters = [];
  var hearted = {};

  function shuffle(arr) {
    var a = arr.slice();
    for (var i = a.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = a[i];
      a[i] = a[j];
      a[j] = tmp;
    }
    return a;
  }

  function createCardEl(letter, i) {
    var el = document.createElement('div');
    el.className = 'letters__card letters__card--animate';
    el.setAttribute('role', 'listitem');
    if (typeof i === 'number') {
      el.style.animationDelay = (i * 80) + 'ms';
    }

    var to = document.createElement('p');
    to.className = 'letters__card-to';
    to.textContent = 'To: ' + letter.addressed_to;

    var body = document.createElement('p');
    body.className = 'letters__card-body';
    body.textContent = letter.body;

    var footer = document.createElement('div');
    footer.className = 'letters__card-footer';

    var from = document.createElement('span');
    from.className = 'letters__card-from';
    from.textContent = '— ' + (letter.signed_from || 'a stranger');

    var heartBtn = document.createElement('button');
    heartBtn.className = 'letters__heart-btn';
    heartBtn.type = 'button';
    heartBtn.setAttribute('aria-label', 'Heart this letter');
    if (hearted[letter.id]) heartBtn.classList.add('letters__heart-btn--active');

    var heartIcon = document.createElement('span');
    heartIcon.className = 'letters__heart-icon';
    heartIcon.textContent = hearted[letter.id] ? '\u2764' : '\u2661';

    var heartCount = document.createElement('span');
    heartCount.textContent = letter.hearts || '';

    heartBtn.appendChild(heartIcon);
    heartBtn.appendChild(heartCount);

    heartBtn.addEventListener('click', async function () {
      if (hearted[letter.id]) return;
      hearted[letter.id] = true;

      // Save to localStorage
      try {
        localStorage.setItem('letters_hearted', JSON.stringify(hearted));
      } catch (e) { /* ignore */ }

      heartBtn.classList.add('letters__heart-btn--active');
      heartIcon.textContent = '\u2764';
      heartIcon.classList.add('letters__heart-icon--pop');
      letter.hearts = (letter.hearts || 0) + 1;
      heartCount.textContent = letter.hearts;

      await supabase
        .from('letters')
        .update({ hearts: letter.hearts })
        .eq('id', letter.id);
    });

    footer.appendChild(from);
    footer.appendChild(heartBtn);

    el.appendChild(to);
    el.appendChild(body);
    el.appendChild(footer);

    return el;
  }

  function renderLetters(letters) {
    var grid = document.getElementById('letters-grid');
    if (!grid) return;
    grid.innerHTML = '';

    if (letters.length === 0) {
      grid.innerHTML = '<div class="letters__empty"><p>No letters yet.</p><p>Be the first to write a message to someone you\'ll never meet. Scroll up and leave a letter for a stranger, your future self, or anyone who needs to hear it.</p></div>';
      return;
    }

    letters.forEach(function (letter, i) {
      grid.appendChild(createCardEl(letter, i));
    });
  }

  async function initLetters() {
    var form = document.getElementById('letters-form');
    var bodyInput = document.getElementById('letters-body');
    var charCount = document.getElementById('letters-char-count');
    var toInput = document.getElementById('letters-to');
    var fromInput = document.getElementById('letters-from');
    var submitBtn = document.getElementById('letters-submit');
    var statusEl = document.getElementById('letters-status');
    var loading = document.getElementById('letters-loading');
    var shuffleBtn = document.getElementById('letters-shuffle');
    var grid = document.getElementById('letters-grid');

    // Restore hearted state
    try {
      var saved = localStorage.getItem('letters_hearted');
      if (saved) hearted = JSON.parse(saved);
    } catch (e) { /* ignore */ }

    // Char counter
    if (bodyInput && charCount) {
      bodyInput.addEventListener('input', function () {
        var len = bodyInput.value.length;
        charCount.textContent = len + ' / 500';
        charCount.className = 'letters__char-count';
        if (len >= 480) charCount.classList.add('letters__char-count--full');
        else if (len >= 400) charCount.classList.add('letters__char-count--warn');
      });
    }

    // Suggestion buttons
    var suggestions = document.querySelectorAll('.letters__suggestion');
    suggestions.forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (toInput) {
          toInput.value = btn.dataset.to;
          toInput.focus();
        }
      });
    });

    // Submit form
    if (form) {
      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        if (!toInput || !bodyInput) return;

        var addressedTo = toInput.value.trim();
        var body = bodyInput.value.trim();
        var signedFrom = (fromInput && fromInput.value.trim()) || 'a stranger';

        if (!addressedTo || !body) return;

        submitBtn.disabled = true;
        submitBtn.classList.add('letters__submit--sending');
        statusEl.hidden = true;

        var result = await supabase
          .from('letters')
          .insert([{
            addressed_to: addressedTo,
            body: body,
            signed_from: signedFrom
          }])
          .select();

        submitBtn.disabled = false;
        submitBtn.classList.remove('letters__submit--sending');

        if (result.error) {
          statusEl.textContent = 'Something went wrong. Try again.';
          statusEl.className = 'letters__status letters__status--error';
          statusEl.hidden = false;
          return;
        }

        // Success
        statusEl.textContent = 'Your letter has been left for someone to find.';
        statusEl.className = 'letters__status';
        statusEl.hidden = false;
        form.reset();
        charCount.textContent = '0 / 500';
        charCount.className = 'letters__char-count';

        // Add the new letter to the grid
        if (result.data && result.data[0]) {
          allLetters.unshift(result.data[0]);
          var card = createCardEl(result.data[0], 0);
          if (grid && grid.firstChild) {
            grid.insertBefore(card, grid.firstChild);
          } else if (grid) {
            grid.innerHTML = '';
            grid.appendChild(card);
          }
        }

        // Clear status after a few seconds
        setTimeout(function () { statusEl.hidden = true; }, 5000);
      });
    }

    // Fetch letters
    var result = await supabase
      .from('letters')
      .select('id,addressed_to,body,signed_from,hearts,created_at')
      .eq('flagged', false)
      .order('created_at', { ascending: false })
      .limit(200);

    if (loading) loading.hidden = true;

    if (result.error || !result.data) {
      if (grid) grid.innerHTML = '<p class="letters__empty">Could not load letters.</p>';
      return;
    }

    allLetters = result.data;
    renderLetters(shuffle(allLetters));

    // Shuffle button
    if (shuffleBtn) {
      shuffleBtn.addEventListener('click', function () {
        renderLetters(shuffle(allLetters));
        // Scroll to grid
        if (grid) grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }
  }

  document.addEventListener('astro:page-load', initLetters);
</script>
