---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const poems = await getCollection('poems');
  const sorted = poems.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((poem, index) => ({
    params: { slug: poem.id.replace(/\.md$/, '') },
    props: {
      poem,
      prevPoem: index > 0 ? sorted[index - 1] : null,
      nextPoem: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { poem, prevPoem, nextPoem } = Astro.props;
const { Content } = await render(poem);
const slug = poem.id.replace(/\.md$/, '');

// Reading time estimate
const rawContent = poem.body || '';
const wordCount = rawContent.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<Base
  title={`${poem.data.title} — Ravings`}
  description={poem.data.excerpt || `Read "${poem.data.title}" from the collection Ravings by Chidi Francis Onwuka.`}
  ogImage={`/og/${slug}.svg`}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Poem",
    "name": poem.data.title,
    "author": { "@type": "Person", "name": "Chidi Francis Onwuka" },
    "datePublished": poem.data.year || "2024",
    "genre": poem.data.theme || "Poetry",
    "description": poem.data.excerpt || `A poem from the collection Ravings.`,
    "isPartOf": { "@type": "Collection", "name": "Ravings" },
    "url": `https://itsowol.com/poems/${slug}/`,
    "inLanguage": "en"
  })} />

  <article class="poem-single" data-poem={slug} aria-label={poem.data.title}>
    <header class="poem-single__header reveal" data-reveal="fade-up">
      <div class="poem-single__meta">
        {poem.data.theme && (
          <span class="poem-single__theme">{poem.data.theme}</span>
        )}
        {poem.data.year && (
          <span class="poem-single__year">{poem.data.year}</span>
        )}
      </div>
      <h1 class="poem-single__title">{poem.data.title}</h1>
      <span class="poem-single__reading-time">{readingTime} min read</span>
      <div class="poem-single__audio" id="poem-audio-wrap" hidden>
        <button class="poem-single__audio-btn" id="poem-audio-btn" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <span id="poem-audio-label">Listen</span>
        </button>
        <audio id="poem-audio" preload="none"></audio>
      </div>
    </header>

    <div class="poem-single__body reveal" data-reveal="fade-up" data-reveal-delay="200">
      <Content />
    </div>

    <footer class="poem-single__footer">
      <nav class="poem-nav" aria-label="Poem navigation">
        {prevPoem && (
          <a
            href={`/poems/${prevPoem.id.replace(/\.md$/, '')}`}
            class="poem-nav__link poem-nav__link--prev reveal"
            data-reveal="fade-up"
          >
            <span class="poem-nav__label">Previous</span>
            <span class="poem-nav__title">{prevPoem.data.title}</span>
          </a>
        )}

        {nextPoem && (
          <a
            href={`/poems/${nextPoem.id.replace(/\.md$/, '')}`}
            class="poem-nav__link poem-nav__link--next reveal"
            data-reveal="fade-up"
            data-reveal-delay="100"
          >
            <span class="poem-nav__label">Next</span>
            <span class="poem-nav__title">{nextPoem.data.title}</span>
          </a>
        )}
      </nav>

      <a href="/" class="poem-single__back reveal" data-reveal="fade" data-reveal-delay="200">
        &larr; All Poems
      </a>
    </footer>
  </article>
</Base>

<script define:vars={{ theme: poem.data.theme || 'Resilience', audioSlug: slug, poemSlug: slug }}>
  window.__poemTheme = theme;
  window.__poemAudioSlug = audioSlug;
  window.__poemSlug = poemSlug;
</script>
<script>
  import { initPoemBg, destroyPoemBg } from '../../scripts/poem-bg.js';

  function setupBg() {
    destroyPoemBg();
    if (document.querySelector('.poem-single')) {
      initPoemBg(window.__poemTheme, window.__poemSlug);
    }
  }

  function setupAudio() {
    var slug = window.__poemAudioSlug;
    var audioPath = '/audio/' + slug + '.mp3';
    var wrap = document.getElementById('poem-audio-wrap');
    var btn = document.getElementById('poem-audio-btn');
    var audio = document.getElementById('poem-audio');
    var label = document.getElementById('poem-audio-label');
    if (!wrap || !btn || !audio) return;

    // Check if audio file exists
    fetch(audioPath, { method: 'HEAD' }).then(function (res) {
      if (res.ok) {
        audio.src = audioPath;
        wrap.hidden = false;

        btn.addEventListener('click', function () {
          if (audio.paused) {
            audio.play();
            if (label) label.textContent = 'Pause';
            btn.classList.add('is-playing');
          } else {
            audio.pause();
            if (label) label.textContent = 'Listen';
            btn.classList.remove('is-playing');
          }
        });

        audio.addEventListener('ended', function () {
          if (label) label.textContent = 'Listen';
          btn.classList.remove('is-playing');
        });
      }
    }).catch(function () {});
  }

  document.addEventListener('astro:page-load', function () {
    setupBg();
    setupAudio();
  });
  document.addEventListener('astro:before-preparation', destroyPoemBg);
</script>
