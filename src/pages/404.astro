---
import Base from '../layouts/Base.astro';
---

<Base title="Not Found — Ravings" description="This page doesn't exist.">
  <div class="page-404">
    <h1 class="page-404__title">404</h1>
    <p class="page-404__text">
      This page wandered off somewhere.<br />
      Perhaps it's writing a poem.
    </p>
    <nav class="page-404__nav">
      <a href="/" class="page-404__link">&larr; Back to Ravings</a>
      <a href="/poems" class="page-404__link">Read the poems</a>
    </nav>
  </div>
</Base>

<style>
  .page-404 {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    padding: 4rem 1.5rem;
  }

  .page-404__title {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: clamp(5rem, 15vw, 10rem);
    font-weight: 400;
    color: var(--color-text-primary, #EFF0ED);
    margin: 0;
    line-height: 1;
    letter-spacing: -0.04em;
    opacity: 0.15;
  }

  .page-404__text {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--color-text-muted, #A6A5A0);
    line-height: 1.7;
    margin: -1rem 0 2rem;
    max-width: 24rem;
  }

  .page-404__nav {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .page-404__link {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: 0.95rem;
    color: var(--color-text-muted, #A6A5A0);
    text-decoration: none;
    padding: 0.5rem 1.2rem;
    border: 1px solid var(--color-separator, rgba(255, 255, 255, 0.06));
    border-radius: 3px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .page-404__link:hover {
    color: var(--color-text-primary, #EFF0ED);
    border-color: rgba(255, 255, 255, 0.15);
  }
</style>
