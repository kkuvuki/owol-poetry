---
import Base from '../layouts/Base.astro';
---

<Base
  title="Voices — Relentlessly Human"
  description="Meet the people who have contributed to the collaborative poem Relentlessly Human."
>
  <article class="voices-page">
    <header class="voices-page__header reveal" data-reveal="fade-up">
      <h1 class="voices-page__title">Voices</h1>
      <p class="page-intro">Meet the people behind every line. Each card shows a contributor's words, where they wrote from, and how many lines they've added to the poem.</p>
      <p class="voices-page__subtitle">Every person who left a line in the poem.</p>
      <div class="voices-page__stats" aria-live="polite">
        <span class="voices-page__stat" id="voices-count">&mdash;</span>
        <span class="voices-page__stat-label">contributors</span>
      </div>
    </header>

    <div class="voices-page__loading" id="voices-loading" aria-live="polite">
      <span class="sr-only">Loading voices</span>
      <span class="rh__loading-dot"></span>
      <span class="rh__loading-dot"></span>
      <span class="rh__loading-dot"></span>
    </div>

    <div class="voices-page__grid" id="voices-grid">
      <!-- Populated by JS -->
    </div>

    <footer class="voices-page__footer reveal" data-reveal="fade-up">
      <a href="/#relentlessly-human" class="voices-page__cta">Add a line to the poem &rarr;</a>
      <a href="/poem" class="voices-page__link">Read the full poem</a>
      <a href="/anthology" class="voices-page__link">Browse by year</a>
    </footer>
  </article>
</Base>

<script>
  import { supabase } from '../scripts/supabase.js';

  async function initVoices() {
    var grid = document.getElementById('voices-grid');
    var loading = document.getElementById('voices-loading');
    var countEl = document.getElementById('voices-count');
    if (!grid) return;

    var result = await supabase
      .from('poem_lines')
      .select('text, author_name, author_link, created_at')
      .eq('flagged', false)
      .order('created_at', { ascending: true })
      .limit(2000);

    if (loading) loading.hidden = true;

    if (result.error) {
      grid.innerHTML = '<p class="voices-page__empty">Unable to load voices right now. Please try refreshing.</p>';
      return;
    }

    var lines = result.data;
    if (!lines || lines.length === 0) {
      grid.innerHTML = '<p class="voices-page__empty">No voices yet. <a href="/#relentlessly-human">Add a line to the poem</a> and your name will appear here.</p>';
      return;
    }

    // Group by author
    var authors = {};
    lines.forEach(function (l) {
      var key = (l.author_name || '').toLowerCase().trim();
      if (!key) return;
      if (!authors[key]) {
        authors[key] = {
          name: l.author_name,
          lines: [],
          socials: null,
          location: null,
          firstSeen: l.created_at,
        };
      }
      authors[key].lines.push(l.text);

      // Use latest socials/location
      if (l.author_link) {
        try {
          var s = JSON.parse(l.author_link);
          if (s && typeof s === 'object') {
            authors[key].socials = s;
            if (s.city || s.country) {
              authors[key].location = [s.city, s.country].filter(Boolean).join(', ');
            }
          }
        } catch (e) {}
      }
    });

    var sorted = Object.values(authors).sort(function (a, b) {
      return b.lines.length - a.lines.length;
    });

    if (countEl) countEl.textContent = sorted.length;

    sorted.forEach(function (author) {
      var card = document.createElement('div');
      card.className = 'voice-card';

      var header = document.createElement('div');
      header.className = 'voice-card__header';

      var name = document.createElement('h3');
      name.className = 'voice-card__name';
      name.textContent = author.name;

      var count = document.createElement('span');
      count.className = 'voice-card__count';
      count.textContent = author.lines.length + ' line' + (author.lines.length !== 1 ? 's' : '');

      header.appendChild(name);
      header.appendChild(count);

      if (author.location) {
        var loc = document.createElement('span');
        loc.className = 'voice-card__location';
        loc.textContent = author.location;
        header.appendChild(loc);
      }

      // Social icons
      if (author.socials) {
        var socials = document.createElement('div');
        socials.className = 'voice-card__socials';
        var iconMap = {
          linkedin: '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>',
          instagram: '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>',
          email: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>',
          website: '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>',
        };
        var urlMap = {
          linkedin: function (v) { return v.startsWith('http') ? v : 'https://linkedin.com/in/' + v; },
          instagram: function (v) { return v.startsWith('http') ? v : 'https://instagram.com/' + v.replace('@', ''); },
          email: function (v) { return 'mailto:' + v; },
          website: function (v) { return v.startsWith('http') ? v : 'https://' + v; },
        };
        ['linkedin', 'instagram', 'email', 'website'].forEach(function (key) {
          if (!author.socials[key]) return;
          var a = document.createElement('a');
          a.href = urlMap[key](author.socials[key]);
          a.target = '_blank';
          a.rel = 'noopener noreferrer';
          a.className = 'voice-card__social';
          a.setAttribute('aria-label', key);
          a.innerHTML = iconMap[key];
          socials.appendChild(a);
        });
        if (socials.childElementCount > 0) header.appendChild(socials);
      }

      // Show their lines
      var linesWrap = document.createElement('div');
      linesWrap.className = 'voice-card__lines';
      author.lines.forEach(function (text) {
        var p = document.createElement('p');
        p.className = 'voice-card__line';
        p.textContent = text;
        linesWrap.appendChild(p);
      });

      card.appendChild(header);
      card.appendChild(linesWrap);
      grid.appendChild(card);
    });
  }

  document.addEventListener('astro:page-load', initVoices);
</script>

<style>
  .voices-page {
    max-width: 56rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }

  .voices-page__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .voices-page__title {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-text-primary, #EFF0ED);
    margin: 0 0 0.5rem;
  }

  .voices-page__subtitle {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--color-text-muted, #A6A5A0);
    margin: 0 0 1.5rem;
  }

  .voices-page__stats {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    padding: 0.5rem 1.2rem;
    background: var(--color-bg-surface, #1C1916);
    border: 1px solid var(--color-separator, rgba(255, 255, 255, 0.06));
    border-radius: 2rem;
    font-size: 0.9rem;
  }

  .voices-page__stat {
    font-weight: 600;
    color: var(--color-text-primary, #EFF0ED);
  }

  .voices-page__stat-label {
    color: var(--color-text-muted, #A6A5A0);
  }

  .voices-page__loading {
    display: flex;
    justify-content: center;
    gap: 0.4rem;
    padding: 3rem 0;
  }

  .voices-page__loading[hidden] {
    display: none;
  }

  .voices-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  /* Cards are JS-created, so use :global() */
  :global(.voice-card) {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-separator, rgba(255, 255, 255, 0.06));
    border-radius: 8px;
    padding: 1.5rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  :global(.voice-card:hover) {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global(.voice-card__header) {
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-separator, rgba(255, 255, 255, 0.06));
  }

  :global(.voice-card__name) {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-text-primary, #EFF0ED);
    margin: 0 0 0.25rem;
  }

  :global(.voice-card__count) {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.78rem;
    color: var(--color-accent-green, #79B939);
    font-weight: 600;
    display: block;
    margin-bottom: 0.25rem;
  }

  :global(.voice-card__location) {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.78rem;
    color: var(--color-text-muted, #A6A5A0);
    display: block;
  }

  :global(.voice-card__socials) {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  :global(.voice-card__social) {
    color: var(--color-text-muted, #A6A5A0);
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
  }

  :global(.voice-card__social:hover) {
    color: var(--color-accent-green, #79B939);
  }

  :global(.voice-card__lines) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  :global(.voice-card__line) {
    font-family: 'Lora', serif;
    font-style: italic;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-secondary, #B0B1AB);
    margin: 0;
    padding-left: 0.75rem;
    border-left: 2px solid var(--color-separator, rgba(255, 255, 255, 0.06));
  }

  :global(.voices-page__empty) {
    grid-column: 1 / -1;
    text-align: center;
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-style: italic;
    color: var(--color-text-muted, #A6A5A0);
    padding: 4rem 0;
  }

  /* Footer */
  .voices-page__footer {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid var(--color-separator, rgba(255, 255, 255, 0.06));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .voices-page__cta {
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: 1rem;
    color: var(--color-text-primary, #EFF0ED);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.1rem;
    transition: opacity 0.2s;
  }

  .voices-page__cta:hover {
    opacity: 0.6;
  }

  .voices-page__link {
    font-size: 0.9rem;
    color: var(--color-text-muted, #A6A5A0);
    text-decoration: none;
    transition: color 0.2s;
  }

  .voices-page__link:hover {
    color: var(--color-text-primary, #EFF0ED);
  }

  @media (max-width: 600px) {
    .voices-page {
      padding: 2.5rem 1rem 4rem;
    }

    .voices-page__grid {
      grid-template-columns: 1fr;
    }
  }

  @media print {
    .voices-page__footer,
    .voices-page__loading {
      display: none;
    }

    :global(.voice-card) {
      break-inside: avoid;
      border: 1px solid #ccc;
    }

    :global(.voice-card__social) {
      display: none;
    }
  }
</style>
