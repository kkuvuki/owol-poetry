---
import Base from '../layouts/Base.astro';
---

<Base
  title="The Full Poem — Relentlessly Human"
  description="Read the entire collaborative poem, written one line at a time by strangers around the world."
>
  <article class="poem-page">
    <header class="poem-page__header reveal" data-reveal="fade-up">
      <h1 class="poem-page__title">Relentlessly Human</h1>
      <p class="poem-page__subtitle">The full poem, from first line to last.</p>
      <div class="poem-page__stats" aria-live="polite">
        <span class="poem-page__stat" id="poem-page-count">&mdash;</span>
        <span class="poem-page__stat-label">lines &middot;</span>
        <span class="poem-page__stat" id="poem-page-authors">&mdash;</span>
        <span class="poem-page__stat-label">voices</span>
      </div>
      <div id="poem-page-presence"></div>
      <div class="poem-page__view-toggle">
        <button class="poem-page__thread-toggle" id="poem-page-thread-toggle" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 17 4 12 9 7"/><path d="M20 18v-2a4 4 0 0 0-4-4H4"/></svg>
          Show threads
        </button>
      </div>
    </header>

    <!-- Quick Actions Toolbar -->
    <div class="poem-page__toolbar">
      <button class="poem-page__toolbar-btn" id="poem-page-reading-mode-top" type="button" title="Immersive reading experience — one line at a time">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        Reading mode
      </button>
      <button class="poem-page__toolbar-btn" id="poem-page-timelapse-top" type="button" title="Watch the poem unfold line by line">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Timelapse
      </button>
      <button class="poem-page__toolbar-btn chapbook-btn" id="poem-page-chapbook-top" type="button" title="Download the poem as a beautifully typeset PDF booklet">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        Chapbook
      </button>
      <button class="poem-page__toolbar-btn" id="poem-page-export-top" type="button" title="Download the poem as a plain text file">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Export
      </button>
    </div>

    <!-- Search -->
    <div class="poem-page__search">
      <label for="poem-page-search" class="sr-only">Search poem lines</label>
      <input
        type="search"
        id="poem-page-search"
        class="poem-page__search-input"
        placeholder="Search lines..."
        autocomplete="off"
      />
    </div>

    <!-- Author filter banner (hidden by default) -->
    <div class="poem-page__filter" id="poem-page-filter" hidden>
      <span class="poem-page__filter-text">
        Showing lines by <strong id="poem-page-filter-name"></strong>
      </span>
      <button class="poem-page__filter-clear" id="poem-page-filter-clear">Show all</button>
    </div>

    <div class="poem-page__body">
      <div class="poem-page__loading" id="poem-page-loading" aria-live="polite">
        <span class="rh__loading-dot"></span>
        <span class="rh__loading-dot"></span>
        <span class="rh__loading-dot"></span>
      </div>

      <div class="poem-page__lines" id="poem-page-lines" role="list" aria-label="Full poem">
        <!-- Lines injected by JS -->
      </div>
    </div>

    <!-- Mood Heatmap Strip -->
    <div class="poem-page__mood reveal" data-reveal="fade-up">
      <h2 class="poem-page__map-title">The poem's emotional journey</h2>
      <div id="poem-page-mood-strip"></div>
    </div>

    <div class="poem-page__map reveal" data-reveal="fade-up">
      <h2 class="poem-page__map-title">Where the voices write from</h2>
      <canvas id="poem-page-map" aria-label="World map showing contributor locations"></canvas>
    </div>

    <footer class="poem-page__footer reveal" data-reveal="fade-up">
      <a href="/#relentlessly-human" class="poem-page__cta">
        Add your line &rarr;
      </a>
      <div class="poem-page__actions">
        <button class="poem-page__action-btn" id="poem-page-export" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Export
        </button>
        <button class="poem-page__action-btn" id="poem-page-reading-mode" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Reading mode
        </button>
        <button class="poem-page__action-btn" id="poem-page-timelapse" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Timelapse
        </button>
        <button class="poem-page__action-btn" id="poem-page-poster" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
          Poster
        </button>
        <button class="poem-page__action-btn chapbook-btn" id="poem-page-chapbook" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          Chapbook
        </button>
        <button class="poem-page__action-btn" id="poem-page-print" type="button" onclick="window.print()">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          Print
        </button>
      </div>
      <div class="poem-page__explore">
        <a href="/anthology" class="poem-page__explore-link">Anthology</a>
        <a href="/ledger" class="poem-page__explore-link">Ledger</a>
        <a href="/languages" class="poem-page__explore-link">Languages</a>
        <a href="/branches" class="poem-page__explore-link">Branches</a>
        <a href="/letters" class="poem-page__explore-link">Letters</a>
        <a href="/pen-pals" class="poem-page__explore-link">Pen Pals</a>
        <a href="/installation" class="poem-page__explore-link">Installation Mode</a>
      </div>
      <a href="/" class="poem-page__back">&larr; Back to Ravings</a>
    </footer>
  </article>

  <!-- Ambient Soundscape Toggle -->
  <button class="soundscape-toggle" id="soundscape-toggle" type="button" aria-label="Toggle ambient soundscape" title="Play ambient soundscape — gentle sounds to read by">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
    <span class="soundscape-toggle__label">Listen</span>
  </button>
  <div class="soundscape-volume" id="soundscape-volume">
    <input type="range" min="0" max="100" value="15" id="soundscape-vol-slider" aria-label="Soundscape volume" />
  </div>

  <!-- Fullscreen Reading Mode overlay -->
  <div class="reading-mode" id="reading-mode" hidden>
    <button class="reading-mode__close" id="reading-mode-close" type="button" aria-label="Exit reading mode">&times;</button>
    <div class="reading-mode__viewport">
      <p class="reading-mode__line" id="reading-mode-line"></p>
      <span class="reading-mode__author" id="reading-mode-author"></span>
    </div>
    <div class="reading-mode__controls">
      <button class="reading-mode__btn" id="reading-mode-prev" type="button">&larr;</button>
      <span class="reading-mode__progress" id="reading-mode-progress"></span>
      <button class="reading-mode__btn" id="reading-mode-next" type="button">&rarr;</button>
      <button class="reading-mode__btn reading-mode__btn--auto" id="reading-mode-auto" type="button">Auto</button>
    </div>
  </div>
</Base>

<script>
  import { supabase } from '../scripts/supabase.js';
  import { shareLine } from '../scripts/share-card.js';
  import { lazyInitContributionMap } from '../scripts/contribution-map.js';
  import { generatePoster, downloadPoster } from '../scripts/qr-poster.js';
  import { initSoundscape } from '../scripts/ambient-soundscape.js';
  import { generateMoodData, renderMoodStrip } from '../scripts/mood-heatmap.js';
  import { generateChapbook, downloadChapbook } from '../scripts/chapbook-pdf.js';
  import { initInkTrail } from '../scripts/ink-trail.js';
  import { initDayNightTheme } from '../scripts/day-night-theme.js';
  import { initPresence, destroyPresence } from '../scripts/live-presence.js';
  import { showAnimatedShareModal } from '../scripts/animated-share.js';

  var allLines = [];
  var subscription = null;

  function createLineEl(line, i) {
    var el = document.createElement('div');
    el.className = 'poem-page__line';
    el.setAttribute('role', 'listitem');
    el.dataset.id = line.id;
    el.dataset.author = (line.author_name || '').toLowerCase().trim();
    if (typeof i === 'number') {
      el.style.animationDelay = Math.min(i * 30, 3000) + 'ms';
    }

    var text = document.createElement('p');
    text.className = 'poem-page__line-text';
    text.textContent = line.text;

    var right = document.createElement('div');
    right.className = 'poem-page__line-right';

    var meta = document.createElement('button');
    meta.className = 'poem-page__line-meta';
    meta.textContent = line.author_name;
    meta.type = 'button';
    meta.setAttribute('aria-label', 'Show all lines by ' + line.author_name);
    meta.addEventListener('click', function () {
      filterByAuthor(line.author_name);
    });

    var shareBtn = document.createElement('button');
    shareBtn.className = 'poem-page__line-share';
    shareBtn.type = 'button';
    shareBtn.setAttribute('aria-label', 'Share this line');
    shareBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>';
    shareBtn.addEventListener('click', function () {
      shareLine(line.text, line.author_name);
    });

    // Animated share button (video)
    var animBtn = document.createElement('button');
    animBtn.className = 'poem-page__line-share';
    animBtn.type = 'button';
    animBtn.setAttribute('aria-label', 'Create animated share card');
    animBtn.title = 'Animated share';
    animBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>';
    animBtn.addEventListener('click', function () {
      showAnimatedShareModal(line.text, line.author_name);
    });

    // Permalink
    var linkBtn = document.createElement('a');
    linkBtn.className = 'poem-page__line-share';
    linkBtn.href = '/line/' + line.id;
    linkBtn.setAttribute('aria-label', 'Permalink');
    linkBtn.title = 'Unique link';
    linkBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';

    right.appendChild(meta);
    right.appendChild(shareBtn);
    right.appendChild(animBtn);
    right.appendChild(linkBtn);
    el.appendChild(text);
    el.appendChild(right);
    return el;
  }

  /**
   * Intelligent stanza breaks — groups lines into stanzas by:
   * 1. Author change (different voice = new stanza)
   * 2. Time gap > 1 hour between lines
   * 3. Every 4-6 lines from the same author (natural rhythm)
   */
  function shouldBreakStanza(prev, curr, runLength) {
    if (!prev) return false;

    // Different author = new stanza
    var prevAuthor = (prev.author_name || '').toLowerCase().trim();
    var currAuthor = (curr.author_name || '').toLowerCase().trim();
    if (prevAuthor !== currAuthor) return true;

    // Time gap > 1 hour
    var gap = new Date(curr.created_at) - new Date(prev.created_at);
    if (gap > 3600000) return true;

    // Natural rhythm: break every 5 lines from same author
    if (runLength >= 5) return true;

    return false;
  }

  function updateStats(lines) {
    var countEl = document.getElementById('poem-page-count');
    var authorsEl = document.getElementById('poem-page-authors');
    if (countEl) countEl.textContent = lines.length;
    if (authorsEl) {
      var seen = {};
      lines.forEach(function (l) {
        var name = (l.author_name || '').toLowerCase().trim();
        if (name) seen[name] = true;
      });
      authorsEl.textContent = Object.keys(seen).length;
    }
  }

  function renderLines(lines, animate) {
    var container = document.getElementById('poem-page-lines');
    if (!container) return;
    container.innerHTML = '';

    if (lines.length === 0) {
      container.innerHTML = '<p class="poem-page__empty">No lines yet. Be the first to write.</p>';
      return;
    }

    var runLength = 0;
    lines.forEach(function (line, i) {
      var prev = i > 0 ? lines[i - 1] : null;
      if (shouldBreakStanza(prev, line, runLength)) {
        var spacer = document.createElement('div');
        spacer.className = 'poem-page__stanza-break';
        spacer.setAttribute('aria-hidden', 'true');
        container.appendChild(spacer);
        runLength = 0;
      }
      runLength++;
      container.appendChild(createLineEl(line, animate ? i : undefined));
    });
  }

  function renderThreadedView(lines) {
    var container = document.getElementById('poem-page-lines');
    if (!container) return;
    container.innerHTML = '';

    // Build a map of parent → replies
    var rootLines = [];
    var replyMap = {};
    lines.forEach(function (line) {
      if (line.reply_to) {
        if (!replyMap[line.reply_to]) replyMap[line.reply_to] = [];
        replyMap[line.reply_to].push(line);
      } else {
        rootLines.push(line);
      }
    });

    rootLines.forEach(function (line, i) {
      container.appendChild(createLineEl(line, i));
      // Render replies indented
      var replies = replyMap[line.id];
      if (replies && replies.length > 0) {
        replies.forEach(function (reply) {
          var el = createLineEl(reply);
          el.classList.add('poem-page__line--reply');
          container.appendChild(el);
        });
      }
    });
  }

  function filterByAuthor(name) {
    var filterEl = document.getElementById('poem-page-filter');
    var filterName = document.getElementById('poem-page-filter-name');
    var key = name.toLowerCase().trim();

    if (filterEl) filterEl.hidden = false;
    if (filterName) filterName.textContent = name;

    var filtered = allLines.filter(function (l) {
      return (l.author_name || '').toLowerCase().trim() === key;
    });
    renderLines(filtered, false);
  }

  function clearFilter() {
    var filterEl = document.getElementById('poem-page-filter');
    if (filterEl) filterEl.hidden = true;
    renderLines(allLines, false);
  }

  function startTimelapse(lines) {
    if (lines.length === 0) return;
    var container = document.getElementById('poem-page-lines');
    if (!container) return;
    container.innerHTML = '';

    // Clear filter
    var filterEl = document.getElementById('poem-page-filter');
    if (filterEl) filterEl.hidden = true;

    var i = 0;
    var speed = Math.max(100, Math.min(800, 30000 / lines.length)); // adaptive speed

    function addNext() {
      if (i >= lines.length) return;
      var el = createLineEl(lines[i]);
      el.classList.add('poem-page__line--new');
      container.appendChild(el);

      // Update counter
      var countEl = document.getElementById('poem-page-count');
      if (countEl) countEl.textContent = i + 1;

      el.scrollIntoView({ behavior: 'smooth', block: 'end' });
      i++;
      if (i < lines.length) setTimeout(addNext, speed);
    }

    addNext();
  }

  function initReadingMode(lines) {
    if (lines.length === 0) return;
    var overlay = document.getElementById('reading-mode');
    var lineEl = document.getElementById('reading-mode-line');
    var authorEl = document.getElementById('reading-mode-author');
    var progressEl = document.getElementById('reading-mode-progress');
    var closeBtn = document.getElementById('reading-mode-close');
    var prevBtn = document.getElementById('reading-mode-prev');
    var nextBtn = document.getElementById('reading-mode-next');
    var autoBtn = document.getElementById('reading-mode-auto');
    if (!overlay || !lineEl) return;

    var current = 0;
    var autoInterval = null;

    function showLine(i) {
      current = Math.max(0, Math.min(i, lines.length - 1));
      lineEl.style.opacity = '0';
      setTimeout(function () {
        lineEl.textContent = lines[current].text;
        if (authorEl) authorEl.textContent = lines[current].author_name;
        if (progressEl) progressEl.textContent = (current + 1) + ' / ' + lines.length;
        lineEl.style.opacity = '1';
      }, 300);
    }

    function close() {
      if (autoInterval) { clearInterval(autoInterval); autoInterval = null; }
      overlay.hidden = true;
      document.body.style.overflow = '';
    }

    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
    showLine(0);

    closeBtn.onclick = close;
    prevBtn.onclick = function () { showLine(current - 1); };
    nextBtn.onclick = function () { showLine(current + 1); };
    autoBtn.onclick = function () {
      if (autoInterval) {
        clearInterval(autoInterval);
        autoInterval = null;
        autoBtn.textContent = 'Auto';
      } else {
        autoInterval = setInterval(function () {
          if (current >= lines.length - 1) { clearInterval(autoInterval); autoInterval = null; autoBtn.textContent = 'Auto'; return; }
          showLine(current + 1);
        }, 4000);
        autoBtn.textContent = 'Pause';
      }
    };

    // Keyboard navigation
    function keyHandler(e) {
      if (overlay.hidden) { document.removeEventListener('keydown', keyHandler); return; }
      if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); showLine(current + 1); }
      else if (e.key === 'ArrowLeft') { showLine(current - 1); }
      else if (e.key === 'Escape') { close(); }
    }
    document.addEventListener('keydown', keyHandler);
  }

  function exportPoem() {
    if (allLines.length === 0) return;
    var text = 'Relentlessly Human\n';
    text += 'A collaborative poem — itsowol.com/poem\n';
    text += '━'.repeat(40) + '\n\n';
    var runLength = 0;
    allLines.forEach(function (line, i) {
      var prev = i > 0 ? allLines[i - 1] : null;
      if (shouldBreakStanza(prev, line, runLength)) {
        text += '\n';
        runLength = 0;
      }
      runLength++;
      text += line.text + '\n';
    });
    text += '\n' + '━'.repeat(40) + '\n';
    text += allLines.length + ' lines · ' + new Date().toLocaleDateString() + '\n';

    var blob = new Blob([text], { type: 'text/plain' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'relentlessly-human.txt';
    a.click();
    URL.revokeObjectURL(url);
  }

  async function initPoemPage() {
    var container = document.getElementById('poem-page-lines');
    var loading = document.getElementById('poem-page-loading');
    var clearBtn = document.getElementById('poem-page-filter-clear');
    var exportBtn = document.getElementById('poem-page-export');
    if (!container) return;

    if (clearBtn) clearBtn.addEventListener('click', clearFilter);
    if (exportBtn) exportBtn.addEventListener('click', exportPoem);

    // Reading mode (bottom + top)
    var readingBtn = document.getElementById('poem-page-reading-mode');
    var readingBtnTop = document.getElementById('poem-page-reading-mode-top');
    var readingHandler = function () { initReadingMode(allLines); };
    if (readingBtn) readingBtn.addEventListener('click', readingHandler);
    if (readingBtnTop) readingBtnTop.addEventListener('click', readingHandler);

    // Timelapse (bottom + top)
    var timelapseBtn = document.getElementById('poem-page-timelapse');
    var timelapseBtnTop = document.getElementById('poem-page-timelapse-top');
    var timelapseHandler = function () { startTimelapse(allLines); };
    if (timelapseBtn) timelapseBtn.addEventListener('click', timelapseHandler);
    if (timelapseBtnTop) timelapseBtnTop.addEventListener('click', timelapseHandler);

    // Export (top)
    var exportBtnTop = document.getElementById('poem-page-export-top');
    if (exportBtnTop) exportBtnTop.addEventListener('click', exportPoem);

    // Poster generator
    var posterBtn = document.getElementById('poem-page-poster');
    if (posterBtn) posterBtn.addEventListener('click', async function () {
      if (allLines.length === 0) return;
      posterBtn.disabled = true;
      posterBtn.textContent = 'Generating...';
      try {
        // Take the 5 most recent lines
        var posterLines = allLines.slice(-5);
        var blob = await generatePoster(posterLines);
        downloadPoster(blob);
      } catch (e) {
        console.error('Poster generation failed:', e);
      } finally {
        posterBtn.disabled = false;
        posterBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg> Poster';
      }
    });

    // Search
    var searchInput = document.getElementById('poem-page-search');
    var searchTimeout = null;
    if (searchInput) {
      searchInput.addEventListener('input', function () {
        clearTimeout(searchTimeout);
        var query = this.value.trim().toLowerCase();
        searchTimeout = setTimeout(function () {
          if (!query) {
            renderLines(allLines, false);
            return;
          }
          var filtered = allLines.filter(function (l) {
            return l.text.toLowerCase().indexOf(query) !== -1 ||
                   (l.author_name || '').toLowerCase().indexOf(query) !== -1;
          });
          renderLines(filtered, false);
        }, 200);
      });
    }

    // Fetch all lines, oldest first
    var result = await supabase
      .from('poem_lines')
      .select('*')
      .eq('flagged', false)
      .order('created_at', { ascending: true })
      .limit(2000);

    if (loading) loading.hidden = true;

    if (result.error || !result.data || result.data.length === 0) {
      container.innerHTML = '<p class="poem-page__empty">No lines yet. Be the first to write.</p>';
      return;
    }

    allLines = result.data;
    updateStats(allLines);
    renderLines(allLines, true);

    // Initialize contribution map (lazy)
    var mapCanvas = document.getElementById('poem-page-map');
    lazyInitContributionMap(mapCanvas, allLines);

    // Mood heatmap strip
    var moodContainer = document.getElementById('poem-page-mood-strip');
    if (moodContainer && allLines.length > 0) {
      try {
        var moodData = generateMoodData(allLines);
        moodContainer._poemLines = allLines.map(function (l) { return l.text; });
        renderMoodStrip(moodContainer, moodData);
      } catch (_e) { console.warn('Mood strip init failed:', _e); }
    }

    // Ink trail + day/night theme
    initInkTrail();
    initDayNightTheme();

    // Live presence counter
    var presenceEl = document.getElementById('poem-page-presence');
    initPresence(presenceEl);

    // Ambient soundscape
    var soundscapeCtrl = null;
    var soundscapeBtn = document.getElementById('soundscape-toggle');
    var soundscapeSlider = document.getElementById('soundscape-vol-slider');
    if (soundscapeBtn) {
      soundscapeBtn.addEventListener('click', function () {
        if (!soundscapeCtrl) {
          soundscapeCtrl = initSoundscape();
        }
        if (soundscapeBtn.classList.contains('is-playing')) {
          soundscapeCtrl.pause();
          soundscapeBtn.classList.remove('is-playing');
        } else {
          soundscapeCtrl.play();
          soundscapeBtn.classList.add('is-playing');
        }
      });
    }
    if (soundscapeSlider) {
      soundscapeSlider.addEventListener('input', function () {
        if (soundscapeCtrl) soundscapeCtrl.setVolume(parseInt(this.value) / 100);
      });
    }

    // Chapbook PDF (bottom + top)
    var chapbookBtn = document.getElementById('poem-page-chapbook');
    var chapbookBtnTop = document.getElementById('poem-page-chapbook-top');
    if (chapbookBtn) {
      chapbookBtn.addEventListener('click', async function () {
        if (allLines.length === 0) return;
        chapbookBtn.disabled = true;
        chapbookBtn.textContent = 'Generating...';
        try {
          var blob = await generateChapbook(allLines);
          downloadChapbook(blob);
        } catch (e) {
          console.error('Chapbook generation failed:', e);
        } finally {
          chapbookBtn.disabled = false;
          chapbookBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg> Chapbook';
        }
      });
    }
    if (chapbookBtnTop) {
      chapbookBtnTop.addEventListener('click', async function () {
        if (allLines.length === 0) return;
        chapbookBtnTop.disabled = true;
        chapbookBtnTop.textContent = 'Generating...';
        try {
          var blob = await generateChapbook(allLines);
          downloadChapbook(blob);
        } catch (e) {
          console.error('Chapbook generation failed:', e);
        } finally {
          chapbookBtnTop.disabled = false;
          chapbookBtnTop.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg> Chapbook';
        }
      });
    }

    // Thread toggle
    var threadToggle = document.getElementById('poem-page-thread-toggle');
    var isThreaded = false;
    if (threadToggle) {
      threadToggle.addEventListener('click', function () {
        isThreaded = !isThreaded;
        threadToggle.textContent = isThreaded ? 'Show linear' : 'Show threads';
        if (isThreaded) {
          renderThreadedView(allLines);
        } else {
          renderLines(allLines, false);
        }
      });
    }

    // Subscribe to realtime inserts
    subscription = supabase
      .channel('poem_page_realtime')
      .on(
        'postgres_changes',
        { event: 'INSERT', schema: 'public', table: 'poem_lines' },
        function (payload) {
          if (payload.new && !payload.new.flagged) {
            // Check for duplicates
            var exists = allLines.some(function (l) { return l.id === payload.new.id; });
            if (exists) return;

            allLines.push(payload.new);
            updateStats(allLines);

            // If no filter active, append the line
            var filterEl = document.getElementById('poem-page-filter');
            if (!filterEl || filterEl.hidden) {
              var el = createLineEl(payload.new);
              el.classList.add('poem-page__line--new');
              container.appendChild(el);
              // Smooth scroll to the new line
              el.scrollIntoView({ behavior: 'smooth', block: 'end' });
            }
          }
        }
      )
      .subscribe();
  }

  // Cleanup on navigation
  document.addEventListener('astro:before-preparation', function () {
    if (subscription) {
      subscription.unsubscribe();
      subscription = null;
    }
    destroyPresence();
  });

  document.addEventListener('astro:page-load', initPoemPage);
</script>
