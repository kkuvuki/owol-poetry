---
import Base from '../layouts/Base.astro';
---

<Base
  title="This Week's Poem — Relentlessly Human"
  description="A poem composed from the voices of strangers, assembled weekly from community-submitted lines."
>
  <article class="weekly-poem">
    <!-- Decorative background orb -->
    <div class="weekly-poem__orb" aria-hidden="true"></div>

    <header class="weekly-poem__header reveal" data-reveal="fade-up">
      <span class="weekly-poem__eyebrow">A composition</span>
      <h1 class="weekly-poem__title">This Week's Poem</h1>
      <div class="weekly-poem__rule" aria-hidden="true">
        <span class="weekly-poem__rule-dot"></span>
      </div>
      <p class="weekly-poem__subtitle">Woven from the lines strangers have left behind.</p>
    </header>

    <div class="weekly-poem__loading" id="weekly-poem-loading" aria-live="polite">
      <span class="rh__loading-dot"></span>
      <span class="rh__loading-dot"></span>
      <span class="rh__loading-dot"></span>
    </div>

    <section class="weekly-poem__body" id="weekly-poem-body" hidden>
      <div class="weekly-poem__stage">
        <blockquote class="weekly-poem__verse" id="weekly-poem-verse">
          <!-- Lines injected by JS -->
        </blockquote>
      </div>

      <div class="weekly-poem__meta" id="weekly-poem-meta">
        <!-- Voice count and date injected by JS -->
      </div>

      <div class="weekly-poem__share" id="weekly-poem-share">
        <span class="weekly-poem__share-label">Share this poem</span>
        <div class="weekly-poem__share-buttons">
          <button class="weekly-poem__share-btn" id="weekly-poem-share-twitter" type="button" aria-label="Share on Twitter">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </button>
          <button class="weekly-poem__share-btn" id="weekly-poem-share-copy" type="button" aria-label="Copy to clipboard">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          </button>
          <button class="weekly-poem__share-btn" id="weekly-poem-share-native" type="button" aria-label="Share">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          </button>
        </div>
      </div>
    </section>

    <section class="weekly-poem__empty" id="weekly-poem-empty" hidden>
      <p class="weekly-poem__empty-text">No weekly poem has been composed yet.</p>
      <p class="weekly-poem__empty-hint">The first composition is on its way. In the meantime, <a href="/poem">add your line</a> to the collective poem.</p>
    </section>

    <footer class="weekly-poem__footer reveal" data-reveal="fade-up">
      <a href="/poem" class="weekly-poem__cta">Add your line &rarr;</a>
      <a href="/weekly-poems" class="weekly-poem__link">Past weekly poems</a>
      <a href="/" class="weekly-poem__back">&larr; Back to Ravings</a>
    </footer>
  </article>
</Base>

<style>
  .weekly-poem {
    max-width: 48rem;
    margin: 0 auto;
    padding: 7rem 1.5rem 6rem;
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    color: var(--color-text-primary, #EFF0ED);
    position: relative;
    overflow: hidden;
  }

  /* ── Floating background orb ── */
  .weekly-poem__orb {
    position: absolute;
    top: -10%;
    right: -15%;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(121, 185, 57, 0.06) 0%, transparent 70%);
    filter: blur(60px);
    pointer-events: none;
    animation: orb-drift 20s ease-in-out infinite alternate;
  }

  @keyframes orb-drift {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-60px, 40px) scale(1.1); }
    100% { transform: translate(30px, -20px) scale(0.95); }
  }

  /* ── Header ── */
  .weekly-poem__header {
    text-align: center;
    margin-bottom: 3.5rem;
    position: relative;
  }

  .weekly-poem__eyebrow {
    display: block;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-accent-green, #79B939);
    margin-bottom: 0.75rem;
    opacity: 0.8;
  }

  .weekly-poem__title {
    font-size: clamp(2.6rem, 6vw, 4rem);
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.01em;
    margin: 0 0 1.5rem;
    color: var(--color-text-primary, #EFF0ED);
    line-height: 1.15;
  }

  .weekly-poem__rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .weekly-poem__rule::before,
  .weekly-poem__rule::after {
    content: '';
    height: 1px;
    width: 3rem;
    background: linear-gradient(90deg, transparent, var(--color-text-muted, #908F8A), transparent);
    opacity: 0.3;
  }

  .weekly-poem__rule-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent-green, #79B939);
    opacity: 0.5;
  }

  .weekly-poem__subtitle {
    font-size: 1.05rem;
    color: var(--color-text-muted, #908F8A);
    font-style: italic;
    margin: 0;
    letter-spacing: 0.03em;
  }

  /* ── Loading ── */
  .weekly-poem__loading {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 4rem 0;
  }

  .weekly-poem__loading[hidden] { display: none; }

  /* ── Body ── */
  .weekly-poem__body { margin-bottom: 3rem; }
  .weekly-poem__body[hidden] { display: none; }

  /* ── Stage — the dramatic poem container ── */
  .weekly-poem__stage {
    position: relative;
    max-width: 38rem;
    margin: 0 auto 2.5rem;
    padding: 3rem 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 2px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.015) 0%, transparent 60%);
  }

  .weekly-poem__stage::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 2rem;
    right: 2rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(121, 185, 57, 0.3), transparent);
  }

  .weekly-poem__stage::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 2rem;
    right: 2rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(121, 185, 57, 0.15), transparent);
  }

  /* ── Verse ── */
  .weekly-poem__verse {
    margin: 0;
    padding: 0;
    border: none;
    position: relative;
    font-family: var(--font-body, 'EB Garamond', Georgia, serif);
  }

  .weekly-poem__verse::before {
    content: '\201C';
    position: absolute;
    top: -1.5rem;
    left: -0.5rem;
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: clamp(4rem, 8vw, 6rem);
    line-height: 1;
    color: var(--color-accent-green, #79B939);
    opacity: 0.1;
    user-select: none;
    pointer-events: none;
  }

  .weekly-poem__line {
    font-size: clamp(1.2rem, 2.5vw, 1.4rem);
    line-height: 1.6;
    color: var(--color-text-primary, #EFF0ED);
    margin: 0 0 1.1rem;
    padding: 0;
    opacity: 0;
    transform: translateY(8px);
    animation: line-appear 0.6s ease forwards;
  }

  .weekly-poem__line:last-child {
    margin-top: 1.5rem;
    margin-bottom: 0;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    font-style: italic;
  }

  @keyframes line-appear {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Closing attribution */
  .weekly-poem__closing {
    display: block;
    margin-top: 2rem;
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: 0.8rem;
    font-style: italic;
    color: var(--color-text-muted, #908F8A);
    text-align: right;
    opacity: 0.5;
    letter-spacing: 0.03em;
  }

  /* ── Meta ── */
  .weekly-poem__meta {
    text-align: center;
    padding: 1.5rem 0;
    color: var(--color-text-muted, #908F8A);
    font-style: italic;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
  }

  .weekly-poem__date-sep { opacity: 0.3; }

  .weekly-poem__date {
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  /* ── Share ── */
  .weekly-poem__share {
    text-align: center;
    margin-top: 2rem;
  }

  .weekly-poem__share-label {
    display: block;
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 0.7rem;
    color: var(--color-text-muted, #908F8A);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.75rem;
  }

  .weekly-poem__share-buttons {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
  }

  .weekly-poem__share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: none;
    color: var(--color-text-muted, #908F8A);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .weekly-poem__share-btn:hover {
    background: var(--color-accent-green, #79B939);
    color: var(--color-bg, #13100D);
    border-color: var(--color-accent-green, #79B939);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(121, 185, 57, 0.2);
  }

  /* ── Empty state ── */
  .weekly-poem__empty {
    text-align: center;
    padding: 4rem 2rem;
  }

  .weekly-poem__empty[hidden] { display: none; }

  .weekly-poem__empty-text {
    font-size: 1.2rem;
    font-style: italic;
    color: var(--color-text-muted, #908F8A);
    margin: 0 0 1rem;
  }

  .weekly-poem__empty-hint {
    font-size: 0.95rem;
    color: var(--color-text-muted, #908F8A);
    margin: 0;
  }

  .weekly-poem__empty-hint a {
    color: var(--color-accent-green, #79B939);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .weekly-poem__empty-hint a:hover {
    border-bottom-color: currentColor;
  }

  /* ── Footer ── */
  .weekly-poem__footer {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-separator, rgba(255, 255, 255, 0.06));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .weekly-poem__cta {
    font-size: 1rem;
    color: var(--color-text-primary, #EFF0ED);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.1rem;
    transition: opacity 0.2s;
  }

  .weekly-poem__cta:hover { opacity: 0.6; }

  .weekly-poem__link {
    font-size: 0.95rem;
    color: var(--color-text-muted, #908F8A);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: all 0.2s;
  }

  .weekly-poem__link:hover {
    color: var(--color-text-primary, #EFF0ED);
    border-bottom-color: currentColor;
  }

  .weekly-poem__back {
    font-size: 0.9rem;
    color: var(--color-text-muted, #908F8A);
    text-decoration: none;
    transition: color 0.2s;
  }

  .weekly-poem__back:hover {
    color: var(--color-text-primary, #EFF0ED);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .weekly-poem {
      padding: 3rem 1rem 4rem;
    }

    .weekly-poem__stage {
      padding: 2rem 1.25rem;
    }

    .weekly-poem__orb {
      width: 300px;
      height: 300px;
      top: -5%;
      right: -20%;
    }

    .weekly-poem__meta {
      flex-direction: column;
      gap: 0.25rem;
    }

    .weekly-poem__date-sep { display: none; }
  }
</style>

<script>
  import { supabase } from '../scripts/supabase.js';

  async function initWeeklyPoem() {
    var loading = document.getElementById('weekly-poem-loading');
    var body = document.getElementById('weekly-poem-body');
    var emptyState = document.getElementById('weekly-poem-empty');
    var verse = document.getElementById('weekly-poem-verse');
    var meta = document.getElementById('weekly-poem-meta');

    if (!verse || !body) return;

    var result = await supabase
      .from('weekly_poems')
      .select('*')
      .order('created_at', { ascending: false })
      .limit(1)
      .single();

    if (loading) loading.hidden = true;

    if (result.error || !result.data) {
      if (emptyState) emptyState.hidden = false;
      return;
    }

    var poem = result.data;
    var lines = poem.lines;

    if (!lines || !Array.isArray(lines) || lines.length === 0) {
      if (emptyState) emptyState.hidden = false;
      return;
    }

    // Render lines with staggered entrance animation
    verse.innerHTML = '';
    lines.forEach(function (line, i) {
      var el = document.createElement('p');
      el.className = 'weekly-poem__line';
      el.style.animationDelay = (i * 0.12) + 's';
      el.textContent = line.text;
      verse.appendChild(el);
    });

    // Closing attribution
    var voiceCount = new Set(lines.map(function (l) {
      return (l.author_name || 'Anonymous').toLowerCase();
    })).size;

    var closing = document.createElement('span');
    closing.className = 'weekly-poem__closing';
    closing.textContent = '\u2014 ' + voiceCount + ' voice' + (voiceCount !== 1 ? 's' : '') + ', woven';
    verse.appendChild(closing);

    // Render meta
    if (meta) {
      var date = new Date(poem.created_at);
      var dateStr = date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      });

      meta.innerHTML =
        '<span>Woven from ' + voiceCount + ' voice' + (voiceCount !== 1 ? 's' : '') + '</span>' +
        '<span class="weekly-poem__date-sep">&middot;</span>' +
        '<span class="weekly-poem__date">Composed ' + dateStr + '</span>';
    }

    body.hidden = false;

    // ── Share buttons ──
    var poemText = lines.map(function (l) { return l.text; }).join('\n');
    var shareText = poemText + '\n\n\u2014 Composed from strangers\' voices\nitsowol.com/weekly-poem';
    var shareUrl = 'https://itsowol.com/weekly-poem';

    var twitterBtn = document.getElementById('weekly-poem-share-twitter');
    if (twitterBtn) {
      twitterBtn.addEventListener('click', function () {
        var tweetUrl = 'https://twitter.com/intent/tweet?text=' +
          encodeURIComponent(shareText);
        window.open(tweetUrl, '_blank', 'width=550,height=420');
      });
    }

    var copyBtn = document.getElementById('weekly-poem-share-copy');
    if (copyBtn) {
      copyBtn.addEventListener('click', function () {
        navigator.clipboard.writeText(shareText).then(function () {
          copyBtn.setAttribute('aria-label', 'Copied!');
          setTimeout(function () {
            copyBtn.setAttribute('aria-label', 'Copy to clipboard');
          }, 2000);
        });
      });
    }

    var nativeBtn = document.getElementById('weekly-poem-share-native');
    if (nativeBtn) {
      if (navigator.share) {
        nativeBtn.addEventListener('click', function () {
          navigator.share({
            title: "This Week's Poem \u2014 Relentlessly Human",
            text: shareText,
            url: shareUrl,
          }).catch(function () {});
        });
      } else {
        nativeBtn.style.display = 'none';
      }
    }
  }

  document.addEventListener('astro:page-load', initWeeklyPoem);
</script>
