---
import Base from '../layouts/Base.astro';
---

<Base
  title="This Week's Poem — Relentlessly Human"
  description="A poem composed from the voices of strangers, assembled weekly from community-submitted lines."
>
  <article class="weekly-poem">
    <header class="weekly-poem__header reveal" data-reveal="fade-up">
      <h1 class="weekly-poem__title">This Week's Poem</h1>
      <p class="weekly-poem__subtitle">Each week, a new poem is woven from the lines strangers have left behind.</p>
    </header>

    <div class="weekly-poem__loading" id="weekly-poem-loading" aria-live="polite">
      <span class="rh__loading-dot"></span>
      <span class="rh__loading-dot"></span>
      <span class="rh__loading-dot"></span>
    </div>

    <section class="weekly-poem__body" id="weekly-poem-body" hidden>
      <blockquote class="weekly-poem__verse" id="weekly-poem-verse">
        <!-- Lines injected by JS -->
      </blockquote>

      <div class="weekly-poem__meta" id="weekly-poem-meta">
        <!-- Voice count and date injected by JS -->
      </div>

      <div class="weekly-poem__share" id="weekly-poem-share">
        <span class="weekly-poem__share-label">Share this poem</span>
        <div class="weekly-poem__share-buttons">
          <button class="weekly-poem__share-btn" id="weekly-poem-share-twitter" type="button" aria-label="Share on Twitter">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </button>
          <button class="weekly-poem__share-btn" id="weekly-poem-share-copy" type="button" aria-label="Copy to clipboard">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          </button>
          <button class="weekly-poem__share-btn" id="weekly-poem-share-native" type="button" aria-label="Share">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          </button>
        </div>
      </div>
    </section>

    <section class="weekly-poem__empty" id="weekly-poem-empty" hidden>
      <p class="weekly-poem__empty-text">No weekly poem has been composed yet.</p>
      <p class="weekly-poem__empty-hint">The first composition is on its way. In the meantime, <a href="/poem">add your line</a> to the collective poem.</p>
    </section>

    <footer class="weekly-poem__footer reveal" data-reveal="fade-up">
      <a href="/poem" class="weekly-poem__cta">Add your line &rarr;</a>
      <a href="/anthology" class="weekly-poem__link">Browse the anthology</a>
      <a href="/" class="weekly-poem__back">&larr; Back to Ravings</a>
    </footer>
  </article>
</Base>

<style>
  .weekly-poem {
    max-width: 48rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    color: var(--color-text-primary, #EFF0ED);
  }

  /* Header */
  .weekly-poem__header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-separator, rgba(255, 255, 255, 0.06));
  }

  .weekly-poem__title {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.02em;
    margin: 0 0 0.3rem;
    color: var(--color-text-primary, #EFF0ED);
  }

  .weekly-poem__subtitle {
    font-size: 1.1rem;
    color: var(--color-text-muted, #908F8A);
    font-style: italic;
    margin: 0;
    letter-spacing: 0.04em;
  }

  /* Loading */
  .weekly-poem__loading {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 4rem 0;
  }

  .weekly-poem__loading[hidden] {
    display: none;
  }

  /* Body */
  .weekly-poem__body {
    margin-bottom: 3rem;
  }

  .weekly-poem__body[hidden] {
    display: none;
  }

  /* Verse */
  .weekly-poem__verse {
    margin: 0 auto 2.5rem;
    padding: 2.5rem 1.5rem 2.5rem 2.5rem;
    max-width: 36rem;
    border: none;
    border-left: 2px solid rgba(121, 185, 57, 0.2);
    position: relative;
    font-family: var(--font-body, 'EB Garamond', Georgia, serif);
  }

  .weekly-poem__verse::before {
    content: '\201C';
    display: block;
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: clamp(4rem, 8vw, 6rem);
    line-height: 1;
    color: var(--color-accent-green, #79B939);
    opacity: 0.12;
    margin-bottom: 0.5rem;
    margin-left: -0.15em;
    user-select: none;
    pointer-events: none;
  }

  .weekly-poem__line {
    font-size: clamp(1.15rem, 2.5vw, 1.35rem);
    line-height: 1.9;
    color: var(--color-text-primary, #EFF0ED);
    margin: 0;
    padding: 0.15rem 0;
    text-indent: 0;
  }

  .weekly-poem__line:last-child {
    margin-top: 1.2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    font-style: italic;
  }

  /* Closing attribution */
  .weekly-poem__verse::after {
    content: '\2014\2009 voices, woven';
    display: block;
    margin-top: 2rem;
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-size: 0.85rem;
    font-style: italic;
    color: var(--color-text-muted, #908F8A);
    text-align: right;
    opacity: 0.5;
  }

  /* Meta */
  .weekly-poem__meta {
    text-align: center;
    padding: 1.5rem 0;
    color: var(--color-text-muted, #908F8A);
    font-style: italic;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
  }

  .weekly-poem__date-sep {
    opacity: 0.3;
  }

  .weekly-poem__date {
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  /* Share */
  .weekly-poem__share {
    text-align: center;
    margin-top: 2rem;
  }

  .weekly-poem__share-label {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-muted, #908F8A);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .weekly-poem__share-buttons {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
  }

  .weekly-poem__share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: 1px solid var(--color-separator, rgba(255, 255, 255, 0.06));
    background: none;
    color: var(--color-text-muted, #908F8A);
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .weekly-poem__share-btn:hover {
    background: var(--color-text-primary, #EFF0ED);
    color: var(--color-bg, #13100D);
    border-color: var(--color-text-primary, #EFF0ED);
  }

  /* Empty state */
  .weekly-poem__empty {
    text-align: center;
    padding: 4rem 2rem;
  }

  .weekly-poem__empty[hidden] {
    display: none;
  }

  .weekly-poem__empty-text {
    font-size: 1.2rem;
    font-style: italic;
    color: var(--color-text-muted, #908F8A);
    margin: 0 0 1rem;
  }

  .weekly-poem__empty-hint {
    font-size: 0.95rem;
    color: var(--color-text-muted, #908F8A);
    margin: 0;
  }

  .weekly-poem__empty-hint a {
    color: var(--color-text-primary, #EFF0ED);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    transition: opacity 0.2s;
  }

  .weekly-poem__empty-hint a:hover {
    opacity: 0.6;
  }

  /* Footer */
  .weekly-poem__footer {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-separator, rgba(255, 255, 255, 0.06));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .weekly-poem__cta {
    font-size: 1rem;
    color: var(--color-text-primary, #EFF0ED);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.1rem;
    transition: opacity 0.2s;
  }

  .weekly-poem__cta:hover {
    opacity: 0.6;
  }

  .weekly-poem__link {
    font-size: 0.95rem;
    color: var(--color-text-muted, #908F8A);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: all 0.2s;
  }

  .weekly-poem__link:hover {
    color: var(--color-text-primary, #EFF0ED);
    border-bottom-color: currentColor;
  }

  .weekly-poem__back {
    font-size: 0.9rem;
    color: var(--color-text-muted, #908F8A);
    text-decoration: none;
    transition: color 0.2s;
  }

  .weekly-poem__back:hover {
    color: var(--color-text-primary, #EFF0ED);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .weekly-poem {
      padding: 2.5rem 1rem 4rem;
    }

    .weekly-poem__verse {
      padding: 1.5rem 1rem 1.5rem 1.5rem;
      border-left-width: 1px;
    }

    .weekly-poem__line {
      line-height: 1.8;
    }

    .weekly-poem__meta {
      flex-direction: column;
      gap: 0.25rem;
    }

    .weekly-poem__date-sep {
      display: none;
    }
  }
</style>

<script>
  import { supabase } from '../scripts/supabase.js';

  async function initWeeklyPoem() {
    var loading = document.getElementById('weekly-poem-loading');
    var body = document.getElementById('weekly-poem-body');
    var emptyState = document.getElementById('weekly-poem-empty');
    var verse = document.getElementById('weekly-poem-verse');
    var meta = document.getElementById('weekly-poem-meta');

    if (!verse || !body) return;

    // Fetch the latest weekly poem
    var result = await supabase
      .from('weekly_poems')
      .select('*')
      .order('created_at', { ascending: false })
      .limit(1)
      .single();

    if (loading) loading.hidden = true;

    if (result.error || !result.data) {
      if (emptyState) emptyState.hidden = false;
      return;
    }

    var poem = result.data;
    var lines = poem.lines;

    if (!lines || !Array.isArray(lines) || lines.length === 0) {
      if (emptyState) emptyState.hidden = false;
      return;
    }

    // Render lines — each on its own line, no author names in the poem
    verse.innerHTML = '';
    lines.forEach(function (line, i) {
      var el = document.createElement('p');
      el.className = 'weekly-poem__line';
      el.textContent = line.text;
      verse.appendChild(el);
    });

    // Render meta
    if (meta) {
      var voiceCount = new Set(lines.map(function (l) {
        return (l.author_name || 'Anonymous').toLowerCase();
      })).size;

      var date = new Date(poem.created_at);
      var dateStr = date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      });

      meta.innerHTML =
        '<span>Woven from ' + voiceCount + ' voice' + (voiceCount !== 1 ? 's' : '') + '</span>' +
        '<span class="weekly-poem__date-sep">&middot;</span>' +
        '<span class="weekly-poem__date">Composed ' + dateStr + '</span>';
    }

    body.hidden = false;

    // ── Share buttons ────────────────────────────────────────────────
    var poemText = lines.map(function (l) { return l.text; }).join('\n');
    var shareText = poemText + '\n\n\u2014 Composed from strangers\' voices\nitsowol.com/weekly-poem';
    var shareUrl = 'https://itsowol.com/weekly-poem';

    // Twitter share
    var twitterBtn = document.getElementById('weekly-poem-share-twitter');
    if (twitterBtn) {
      twitterBtn.addEventListener('click', function () {
        var tweetUrl = 'https://twitter.com/intent/tweet?text=' +
          encodeURIComponent(shareText);
        window.open(tweetUrl, '_blank', 'width=550,height=420');
      });
    }

    // Copy to clipboard
    var copyBtn = document.getElementById('weekly-poem-share-copy');
    if (copyBtn) {
      copyBtn.addEventListener('click', function () {
        navigator.clipboard.writeText(shareText).then(function () {
          copyBtn.setAttribute('aria-label', 'Copied!');
          setTimeout(function () {
            copyBtn.setAttribute('aria-label', 'Copy to clipboard');
          }, 2000);
        });
      });
    }

    // Native share
    var nativeBtn = document.getElementById('weekly-poem-share-native');
    if (nativeBtn) {
      if (navigator.share) {
        nativeBtn.addEventListener('click', function () {
          navigator.share({
            title: "This Week's Poem \u2014 Relentlessly Human",
            text: shareText,
            url: shareUrl,
          }).catch(function () {});
        });
      } else {
        nativeBtn.style.display = 'none';
      }
    }
  }

  document.addEventListener('astro:page-load', initWeeklyPoem);
</script>
